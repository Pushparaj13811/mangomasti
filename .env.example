# Copy this file to .env and fill in the values

# PostgreSQL credentials (used by docker-compose)
POSTGRES_USER=mangomasti
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=mangomasti

# Full database connection string (used by the app and drizzle-kit)
DATABASE_URL=postgresql://mangomasti:your_secure_password_here@localhost:5432/mangomasti
